{
  "collectionName": "components_elements_design_info_rows",
  "info": {
    "displayName": "Design Info Row",
    "description": "Alternating two-column row with heading, description, feature tags, CTA, and image."
  },
  "options": {},
  "attributes": {
    "heading": {
      "type": "blocks"
    },
    "description": {
      "type": "text"
    },
    "features": {
      "type": "component",
      "repeatable": true,
      "component": "shared.tag"
    },
    "cta": {
      "type": "component",
      "repeatable": false,
      "component": "elements.link-basic"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "imagePosition": {
      "type": "enumeration",
      "enum": ["left", "right"],
      "default": "left"
    }
  }
}
