{
  "collectionName": "components_case_study_responsive_design_sections",
  "info": {
    "displayName": "Responsive Design Section",
    "description": "Section label, heading, description, responsive mockup images, a row of process steps (icon + title + description), and optional background illustration."
  },
  "options": {},
  "attributes": {
    "label": {
      "type": "string",
      "default": "Responsive Design"
    },
    "heading": {
      "type": "blocks"
    },
    "description": {
      "type": "text"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "steps": {
      "type": "component",
      "component": "elements.steps",
      "repeatable": true
    },
    "backgroundImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    }
  },
  "config": {}
}
