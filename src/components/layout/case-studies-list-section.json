      "relation": "manyToMany",
      "target": "api::case-study.case-study"
    },
    "filterIndustries": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::industry.industry"
    },
    "paddingTop": {
      "type": "integer",
      "min": 0
    },
    "paddingBottom": {
      "type": "integer",
      "min": 0
    },
    "marginTop": {
      "type": "integer",
      "min": 0
    },
    "marginBottom": {
      "type": "integer",
      "min": 0
    }
  },
  "config": {}
}
