{
  "kind": "collectionType",
  "collectionName": "clutch_reviews",
  "info": {
    "singularName": "clutch-review",
    "pluralName": "clutch-reviews",
    "displayName": "Clutch Reviews",
    "description": "Reusable Clutch-style client reviews. Create once, link from case studies and page sections."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "companyName": {
      "type": "string",
      "required": true
    },
    "headline": {
      "type": "string",
      "required": true
    },
    "reviewText": {
      "type": "text",
      "required": true
    },
    "reviewerAvatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images", "files"]
    },
    "reviewerName": {
      "type": "string",
      "required": true
    },
    "reviewerTitle": {
      "type": "string",
      "required": true
    }
  }
}
