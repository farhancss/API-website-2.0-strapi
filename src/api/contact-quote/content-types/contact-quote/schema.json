{
  "kind": "singleType",
  "collectionName": "contact_quotes",
  "info": {
    "singularName": "contact-quote",
    "pluralName": "contact-quotes",
    "displayName": "Contact Quote",
    "description": "Shared Contact Quote section content. Edit once and reuse on multiple pages."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
    "attributes": {
    "heading": {
      "type": "blocks"
    },
    "nextStepsHeading": {
      "type": "string",
      "default": "What happens next?"
    },
    "nextSteps": {
      "type": "component",
      "repeatable": true,
      "component": "shared.tag"
    },
    "phonePrompt": {
      "type": "blocks"
    },
    "awardsHeading": {
      "type": "string",
      "default": "We are an award winning digital agency."
    },
    "awards": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "hubspotForm": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::hub-spot-form.hub-spot-form"
    }
  }
}
