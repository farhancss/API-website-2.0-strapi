{
  "kind": "collectionType",
  "collectionName": "portfolios",
  "info": {
    "singularName": "portfolio",
    "pluralName": "portfolios",
    "displayName": "Portfolio"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "projectType": {
      "type": "string"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "industry": {
      "type": "string"
    },
    "industryCategory": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::industry.industry"
    },
    "services": {
      "type": "component",
      "component": "elements.badge",
      "repeatable": true
    },
    "technologies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::technology.technology"
    },
    "platforms": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "integrations": {
      "type": "component",
      "component": "elements.link-basic",
      "repeatable": true
    },
    "overview": {
      "type": "blocks"
    },
    "copyLink": {
      "type": "string"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "sharedSections": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::portfolio-shared.portfolio-shared"
    }
  }
}
