{
  "kind": "collectionType",
  "collectionName": "featured_case_studies",
  "info": {
    "singularName": "featured-case-study",
    "pluralName": "featured-case-studies",
    "displayName": "Featured Case Studies"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "companyName": {
      "type": "string"
    },

    "slug": {
      "type": "uid",
      "targetField": "companyName"
    },

    "type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::industry.industry"
    },

    "mainImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },

    "tags": {
      "type": "component",
      "repeatable": true,
      "component": "shared.tag"
    },

    "title": {
      "type": "blocks"
    },

    "testimonial": {
      "type": "component",
      "repeatable": false,
      "component": "shared.testimonial"
    }
  }
}