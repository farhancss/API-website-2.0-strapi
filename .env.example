HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# strapi-plugin-backup (disabled by default; set BACKUP_ENABLED=true to enable)
BACKUP_ENABLED=false
BACKUP_CRON_SCHEDULE=0 2 * * *
BACKUP_STORAGE_SERVICE=aws-s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
SQLITE3_EXECUTABLE=/usr/bin/sqlite3
BACKUP_ALLOW_CLEANUP=false
BACKUP_RETENTION_SECONDS=172800
BACKUP_CLEANUP_CRON_SCHEDULE=0 3 * * *
